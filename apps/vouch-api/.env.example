# Database
DATABASE_URL=postgresql://percival:percival-local-dev@localhost:5432/vouch

# NWC — Nostr Wallet Connect (platform Lightning treasury)
# Get this from Alby Hub: Connections → Add Connection → copy Connection Secret
NWC_URL=nostr+walletconnect://<wallet-pubkey>?relay=<relay-url>&secret=<hex-secret>

# Webhook auth (optional — for Alby Hub payment notifications)
# WEBHOOK_SECRET=<random-secret-string>

# Encryption (AES-256-GCM for NWC connection strings at rest)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=<64-char-hex-string>

# CORS origins (comma-separated)
VOUCH_CORS_ORIGINS=http://localhost:3600

# ERC-8004 (optional)
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# PL Treasury Auto-Staking (optional — sensible defaults)
# PL_STAKER_ID=pl-treasury
# PL_OPERATING_RESERVE_SATS=50000
# PL_MAX_POOL_CONCENTRATION_BPS=2000
# PL_EXTRACTION_THRESHOLD_SATS=10000000
