DATABASE_URL=postgresql://user:pass@localhost:5432/vouch
JWT_SECRET=change-me-to-at-least-32-characters
PORT=3601
NODE_ENV=production
VOUCH_CORS_ORIGIN=https://vouch.percivallabs.com
TRUSTED_PROXY_IPS=

# Optional
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
WOT_ENABLED=true
WOT_BASE_URL=https://wot.klabo.world
WOT_CACHE_TTL_HOURS=24
WOT_TIMEOUT_MS=3000
WOT_COMMUNITY_WEIGHT=0.30
WOT_VERIFICATION_BONUS_MAX=120

# NIP-85 service signing key (generate with: npx @vouch/agent-sdk keygen)
VOUCH_SERVICE_NSEC=
